{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "db: up & wait",
      "type": "shell",
      "command": "docker-compose up -d db && until docker exec frontend-study-lab-db-1 pg_isready -U studylab >/dev/null 2>&1; do sleep 1; done",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "build-debug-current-ts",
      "type": "shell",
      "command": "npx",
      "args": [
        "tsc",
        "${file}",
        "--target",
        "ES2020",
        "--module",
        "ES2020",
        "--moduleResolution",
        "Bundler",
        "--types",
        "node",
        "--skipLibCheck",
        "--sourceMap",
        "--outDir",
        ".vscode/.debug-temp"
      ],
      "problemMatcher": ["$tsc"],
      "group": "build"
    }
  ]
}

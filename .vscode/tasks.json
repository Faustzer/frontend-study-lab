{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-debug-current-ts",
      "type": "shell",
      "command": "npx",
      "args": [
        "tsc",
        "${file}",
        "--target",
        "ES2020",
        "--module",
        "ES2020",
        "--moduleResolution",
        "Bundler",
        "--types",
        "node",
        "--skipLibCheck",
        "--sourceMap",
        "--outDir",
        ".vscode/.debug-temp"
      ],
      "problemMatcher": ["$tsc"],
      "group": "build"
    }
  ]
}

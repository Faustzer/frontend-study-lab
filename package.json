{
  "name": "frontend-study-lab",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22"
  },
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "dev-wait": "wait-on tcp:5433 http-get://localhost:8000/health && pnpm run dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck",
    "lint": "eslint --config frontend/eslint.config.mjs frontend/",
    "lint:fix": "eslint --config frontend/eslint.config.mjs frontend/ --fix",
    "test": "vitest --config frontend/vitest.config.ts",
    "test:run": "vitest run --config frontend/vitest.config.ts",
    "test:e2e": "playwright test --config frontend/playwright.config.ts",
    "prepare": "husky",
    "generate": "nuxt generate",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@pinia/nuxt": "^1.0.1",
    "nuxt": "^4.4.8",
    "pinia": "^4.0.2",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.40",
    "vue-i18n": "^9.14.5",
    "vue-router": "^5.2.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@iconify/vue": "^5.0.1",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.61.1",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^17.0.8",
    "msw": "^2.15.0",
    "sass": "^1.87.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7",
    "wait-on": "^9.0.10"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx,vue}": [
      "eslint --config frontend/eslint.config.mjs --fix"
    ],
    "frontend/**/*.{md,json,scss,css}": [
      "eslint --config frontend/eslint.config.mjs --fix"
    ]
  },
  "msw": {
    "workerDirectory": [
      "frontend/public"
    ]
  }
}

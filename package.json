{
  "name": "frontend-study-lab",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config frontend/vite.config.ts",
    "build": "vue-tsc --project frontend/tsconfig.app.json --noEmit && vite build --config frontend/vite.config.ts",
    "preview": "vite preview --config frontend/vite.config.ts",
    "typecheck": "vue-tsc --project frontend/tsconfig.app.json --noEmit",
    "lint": "eslint --config frontend/eslint.config.mjs frontend/",
    "lint:fix": "eslint --config frontend/eslint.config.mjs frontend/ --fix",
    "test": "vitest --config frontend/vitest.config.ts",
    "test:run": "vitest run --config frontend/vitest.config.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "pinia": "^3.0.2",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.13",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.13.2",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^22.15.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.25.1",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^17.0.7",
    "msw": "^2.14.6",
    "sass": "^1.87.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue-tsc": "^2.2.10"
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "eslint --fix"
    ],
    "*.{md,json,scss,css}": [
      "eslint --fix"
    ]
  }
}

# Database — local Docker
DATABASE_URL=postgresql://studylab:studylab@localhost:5432/studylab

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# OAuth2: Google — https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth2: Twitch — https://dev.twitch.tv/console
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# OAuth2: Discord — https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# CORS — allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

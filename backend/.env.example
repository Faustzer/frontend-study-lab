# Database — local Docker (docker-compose maps the db to host port 5433;
# note the +asyncpg driver in the scheme)
DATABASE_URL=postgresql+asyncpg://studylab:studylab@localhost:5433/studylab

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# Frontend URL — OAuth callback redirects the browser here
FRONTEND_URL=http://localhost:5173

# CORS — allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Enable POST /api/auth/dev-login (mock login without OAuth).
# For local development only — NEVER enable in production.
DEV_LOGIN_ENABLED=false

# OAuth2: Google — https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth2: Twitch — https://dev.twitch.tv/console
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# OAuth2: Discord — https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
